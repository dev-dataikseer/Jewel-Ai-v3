# API
PORT=8000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# Database (PostgreSQL or SQLite for dev)
DATABASE_URL=postgresql://jewel:jewel@localhost:5432/jewel_ai

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=3

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
FERNET_KEY=generate-with-python-cryptography-fernet-generate-key

# Admin seed user
ADMIN_EMAIL=admin@jewelai.com
ADMIN_PASSWORD=changeme

# Default studio user (role: user)
DEFAULT_USER_EMAIL=studio@jewelai.com
DEFAULT_USER_PASSWORD=studio123

# Prompt TXT re-import on startup (auto-enabled in development only)
ALLOW_PROMPT_RESEED=

# fal.ai (primary image generation provider)
FAL_KEY=

# Storage (local uploads for dev; set R2_* for production)
STORAGE_BACKEND=local
UPLOADS_DIR=uploads

# R2 / S3 (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_PUBLIC_URL=
