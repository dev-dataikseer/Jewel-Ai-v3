NODE_ENV=production
# Prefer Alembic migrations over SQLAlchemy create_all (required in prod).
SCHEMA_VIA_ALEMBIC=true
DATABASE_URL=postgresql://jewel:jewel@postgres:5432/jewel_ai
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
JWT_SECRET=replace-with-a-strong-random-secret
FERNET_KEY=
FAL_KEY=
# Admin-scoped key required for Platform Billing (credits). Create at fal.ai/dashboard/keys
FAL_ADMIN_KEY=
FAL_CREDITS_LOW_THRESHOLD=5
FAL_BILLING_REFRESH_MINUTES=15
MEDIA_SIGNED_URL_TTL_SECONDS=7200


# Public site URL (Railway — same origin; API serves SPA + /api routes)
API_PUBLIC_URL=https://jewel-ai.up.railway.app
FRONTEND_ORIGIN=https://jewel-ai.up.railway.app

ADMIN_EMAIL=admin@jewelai.com
ADMIN_PASSWORD=change-this-password
DEFAULT_USER_EMAIL=studio@jewelai.com
DEFAULT_USER_PASSWORD=change-this-password
# Object storage (Railway Bucket / Cloudflare R2) — durable input + output files
STORAGE_BACKEND=r2
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

ALLOW_PROMPT_RESEED=false
