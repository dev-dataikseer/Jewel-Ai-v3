FROM python:3.12-slim
WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

COPY backend/requirements.lock.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY backend /app
COPY data/seed-prompt-templates /app/data/seed-prompt-templates

CMD ["sh", "-c", "celery -A app.tasks.celery_app.celery_app worker --beat --loglevel=INFO --concurrency=${CELERY_WORKER_CONCURRENCY:-2}"]
