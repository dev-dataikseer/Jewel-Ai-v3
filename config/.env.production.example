NODE_ENV=production
DATABASE_URL=postgresql://jewel:jewel@postgres:5432/jewel_ai
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
JWT_SECRET=replace-with-a-strong-random-secret
FERNET_KEY=
FAL_KEY=

# Public site URL (same origin — nginx proxies /api and /uploads to the API container)
API_PUBLIC_URL=https://hj-jewel-ai.data-ikseer.com
FRONTEND_ORIGIN=https://hj-jewel-ai.data-ikseer.com

ADMIN_EMAIL=admin@jewelai.com
ADMIN_PASSWORD=change-this-password
DEFAULT_USER_EMAIL=studio@jewelai.com
DEFAULT_USER_PASSWORD=change-this-password
ALLOW_PROMPT_RESEED=false
